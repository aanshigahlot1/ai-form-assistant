# backend/.env.example
# Copy this to backend/.env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/ai-form-assistant
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/ai-form-assistant
MONGODB_URI=mongodb://localhost:27017/ai-form-assistant

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (extension URLs added automatically)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── ChromaDB (optional — for vector memory) ───────────────────────────────────
# Run locally: docker run -p 8000:8000 chromadb/chroma
CHROMA_URL=http://localhost:8000

# ── Security (optional — shared secret for production deployments) ────────────
# API_SECRET=your-random-secret-here
